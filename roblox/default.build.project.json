{
  "name": "ArnisRoblox",
  "servePort": 34872,
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$path": "src/ReplicatedStorage"
    },
    "ServerScriptService": {
      "$path": "src/ServerScriptService"
    },
    "ServerStorage": {
      "$path": "src/ServerStorage"
    },
    "Lighting": {
      "$className": "Lighting",
      "$path": "src/Lighting",
      "$properties": {
        "Technology": "Future",
        "GlobalShadows": true,
        "Brightness": 2,
        "EnvironmentDiffuseScale": 1,
        "EnvironmentSpecularScale": 1,
        "ShadowSoftness": 0.2
      }
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$path": "src/StarterPlayer/StarterPlayerScripts"
      }
    },
    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "StreamingEnabled": false
      },
      "$path": "src/Workspace"
    }
  }
}