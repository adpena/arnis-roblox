{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/chunk-manifest.schema.json",
  "title": "Arnis Roblox Chunk Manifest",
  "type": "object",
  "required": ["schemaVersion", "meta", "chunks"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.4.0"
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "chunks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/chunk"
      }
    }
  },
  "$defs": {
    "bbox": {
      "type": "object",
      "required": ["minLat", "minLon", "maxLat", "maxLon"],
      "properties": {
        "minLat": { "type": "number" },
        "minLon": { "type": "number" },
        "maxLat": { "type": "number" },
        "maxLon": { "type": "number" }
      },
      "additionalProperties": false
    },
    "meta": {
      "type": "object",
      "required": [
        "worldName",
        "generator",
        "source",
        "metersPerStud",
        "chunkSizeStuds",
        "bbox",
        "totalFeatures"
      ],
      "properties": {
        "worldName": { "type": "string" },
        "generator": { "type": "string" },
        "source": { "type": "string" },
        "metersPerStud": { "type": "number", "exclusiveMinimum": 0 },
        "chunkSizeStuds": { "type": "integer", "minimum": 16 },
        "bbox": { "$ref": "#/$defs/bbox" },
        "totalFeatures": { "type": "integer", "minimum": 0 },
        "canonicalAnchor": { "$ref": "#/$defs/canonicalAnchor" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "canonicalAnchor": {
      "type": "object",
      "properties": {
        "positionStuds": { "$ref": "#/$defs/point3" },
        "positionOffsetFromHeuristicStuds": { "$ref": "#/$defs/point3" },
        "lookDirectionStuds": { "$ref": "#/$defs/point3" }
      },
      "additionalProperties": false
    },
    "point2": {
      "type": "object",
      "required": ["x", "z"],
      "properties": {
        "x": { "type": "number" },
        "z": { "type": "number" }
      },
      "additionalProperties": false
    },
    "point3": {
      "type": "object",
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      },
      "additionalProperties": false
    },
    "color": {
      "type": "object",
      "required": ["r", "g", "b"],
      "properties": {
        "r": { "type": "integer", "minimum": 0, "maximum": 255 },
        "g": { "type": "integer", "minimum": 0, "maximum": 255 },
        "b": { "type": "integer", "minimum": 0, "maximum": 255 }
      },
      "additionalProperties": false
    },
    "Color": {
      "type": "object",
      "required": ["r", "g", "b"],
      "properties": {
        "r": { "type": "integer", "minimum": 0, "maximum": 255 },
        "g": { "type": "integer", "minimum": 0, "maximum": 255 },
        "b": { "type": "integer", "minimum": 0, "maximum": 255 }
      },
      "additionalProperties": false
    },
    "terrainGrid": {
      "type": "object",
      "required": ["cellSizeStuds", "width", "depth", "heights", "material"],
      "properties": {
        "cellSizeStuds": { "type": "integer", "minimum": 1 },
        "width": { "type": "integer", "minimum": 1 },
        "depth": { "type": "integer", "minimum": 1 },
        "heights": {
          "type": "array",
          "items": { "type": "number" }
        },
        "materials": {
          "type": "array",
          "items": { "type": "string" }
        },
        "material": { "type": "string" }
      },
      "additionalProperties": false
    },
    "road": {
      "type": "object",
      "required": ["id", "kind", "widthStuds", "points", "material", "hasSidewalk"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "material": { "type": "string" },
        "color": { "$ref": "#/$defs/color" },
        "lanes": { "type": "integer", "minimum": 1 },
        "widthStuds": { "type": "number", "exclusiveMinimum": 0 },
        "hasSidewalk": { "type": "boolean" },
        "elevated": { "type": "boolean", "default": false },
        "tunnel": { "type": "boolean", "default": false },
        "sidewalk": { "type": "string", "enum": ["both", "left", "right", "no"] },
        "surface": { "type": "string" },
        "points": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/point3" }
        }
      },
      "additionalProperties": false
    },
    "rail": {
      "type": "object",
      "required": ["id", "kind", "widthStuds", "points", "material"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "material": { "type": "string" },
        "color": { "$ref": "#/$defs/color" },
        "lanes": { "type": "integer", "minimum": 1 },
        "widthStuds": { "type": "number", "exclusiveMinimum": 0 },
        "points": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/point3" }
        }
      },
      "additionalProperties": false
    },
    "building": {
      "type": "object",
      "required": ["id", "footprint", "baseY", "height", "roof", "material"],
      "properties": {
        "id": { "type": "string" },
        "material": { "type": "string" },
        "wallColor": { "$ref": "#/$defs/Color" },
        "roofColor": { "$ref": "#/$defs/Color" },
        "roofShape": { "type": "string" },
        "roofMaterial": { "type": "string" },
        "usage": { "type": "string" },
        "minHeight": { "type": "number" },
        "footprint": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/point2" }
        },
        "indices": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "baseY": { "type": "number" },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "height_m": { "type": "number", "exclusiveMinimum": 0 },
        "levels": { "type": "integer", "minimum": 0 },
        "roofLevels": { "type": "integer", "minimum": 0 },
        "roof": { "type": "string" },
        "facadeStyle": { "type": "string" },
        "rooms": {
          "type": "array",
          "items": { "$ref": "#/$defs/room" }
        }
      },
      "additionalProperties": false
    },
    "water": {
      "type": "object",
      "required": ["id", "kind", "material"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "material": { "type": "string" },
        "color": { "$ref": "#/$defs/color" },
        "surfaceY": { "type": "number" },
        "widthStuds": { "type": "number", "exclusiveMinimum": 0 },
        "points": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/point3" }
        },
        "footprint": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/point2" }
        },
        "indices": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "holes": {
          "type": "array",
          "items": {
            "type": "array",
            "minItems": 3,
            "items": { "$ref": "#/$defs/point2" }
          }
        }
      },
      "additionalProperties": false
    },
    "prop": {
      "type": "object",
      "required": ["id", "kind", "position", "yawDegrees", "scale"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "position": { "$ref": "#/$defs/point3" },
        "yawDegrees": { "type": "number" },
        "scale": { "type": "number", "exclusiveMinimum": 0 },
        "species": { "type": "string" }
      },
      "additionalProperties": false
    },
    "landuse": {
      "type": "object",
      "required": ["id", "kind", "material", "footprint"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "material": { "type": "string" },
        "footprint": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/point2" }
        }
      },
      "additionalProperties": false
    },
    "barrier": {
      "type": "object",
      "required": ["id", "kind", "points"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "points": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/point3" }
        }
      },
      "additionalProperties": false
    },
    "room": {
      "type": "object",
      "required": ["id", "name", "footprint", "floorY", "height"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "footprint": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/point2" }
        },
        "floorY": { "type": "number" },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "wallMaterial": { "type": "string" },
        "floorMaterial": { "type": "string" },
        "hasDoor": { "type": "boolean" },
        "hasWindow": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "chunk": {
      "type": "object",
      "required": ["id", "originStuds"],
      "properties": {
        "id": { "type": "string" },
        "originStuds": { "$ref": "#/$defs/point3" },
        "terrain": { "$ref": "#/$defs/terrainGrid" },
        "roads": {
          "type": "array",
          "items": { "$ref": "#/$defs/road" }
        },
        "rails": {
          "type": "array",
          "items": { "$ref": "#/$defs/rail" }
        },
        "buildings": {
          "type": "array",
          "items": { "$ref": "#/$defs/building" }
        },
        "water": {
          "type": "array",
          "items": { "$ref": "#/$defs/water" }
        },
        "props": {
          "type": "array",
          "items": { "$ref": "#/$defs/prop" }
        },
        "landuse": {
          "type": "array",
          "items": { "$ref": "#/$defs/landuse" }
        },
        "barriers": {
          "type": "array",
          "items": { "$ref": "#/$defs/barrier" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
